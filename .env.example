# --- APP SETTINGS ---
# The public URL of the application (e.g., https://example.com)
NUXT_PUBLIC_SITE_URL=

# Application base path (e.g., / or /some-folder/)
NUXT_APP_BASE_URL=

# --- SECURITY ---
# Comma-separated list of allowed hosts for Vite dev server NUXT_ALLOWED_HOSTS="example.com,foo.com"
NUXT_ALLOWED_HOSTS=

# --- API KEYS ---
# DeepSeek API Key (Get it at: https://platform.deepseek.com)
DEEPSEEK_API_KEY=your_api_key_here

# --- BITRIX24 LIST SETTINGS ---
# Universal list (iblock) where bank operations are stored.
# Only identifiers of the list itself and static reference items are kept here —
# property IDs and list-value IDs are resolved at runtime via `lists.field.get`
# using XML_ID (symbolic codes) of fields and list values.
NUXT_PUBLIC_B24_IBLOCK_TYPE_ID=lists
NUXT_PUBLIC_B24_IBLOCK_ID=31

# Element ID of the "My company" record that should be attached to every imported operation.
NUXT_PUBLIC_B24_MY_COMPANY_ID=10216

# Element IDs of the "Article" reference for income / outcome operations.
NUXT_PUBLIC_B24_ARTICLE_ID_IN=10214
NUXT_PUBLIC_B24_ARTICLE_ID_OUT=10215
