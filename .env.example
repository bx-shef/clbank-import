# --- APP SETTINGS ---
# The public URL of the application (e.g., https://example.com)
NUXT_PUBLIC_SITE_URL=

# Application base path (e.g., / or /some-folder/)
NUXT_APP_BASE_URL=

# --- SECURITY ---
# Comma-separated list of allowed hosts for Vite dev server NUXT_ALLOWED_HOSTS="example.com,foo.com"
NUXT_ALLOWED_HOSTS=

# --- API KEYS ---
# DeepSeek API Key (Get it at: https://platform.deepseek.com)
DEEPSEEK_API_KEY=your_api_key_here

# --- BITRIX24 LIST SETTINGS ---
# Universal list (iblock) where bank operations are stored.
# Override these to match YOUR Bitrix24 account.
# All values may be left empty in dev — fallbacks are defined in nuxt.config.ts.
NUXT_PUBLIC_B24_IBLOCK_TYPE_ID=lists
NUXT_PUBLIC_B24_IBLOCK_ID=

# Property IDs of the list fields. Provide numeric ID only (e.g. 175) —
# the "PROPERTY_" prefix is added by the app automatically.
NUXT_PUBLIC_B24_FIELD_PAYMENT_TYPE=
NUXT_PUBLIC_B24_FIELD_AMOUNT=
NUXT_PUBLIC_B24_FIELD_CURRENCY=
NUXT_PUBLIC_B24_FIELD_OPERATION_DATE=
NUXT_PUBLIC_B24_FIELD_DOC_NUMBER=
NUXT_PUBLIC_B24_FIELD_OUR_ACC=
NUXT_PUBLIC_B24_FIELD_CLIENT_ACC=
NUXT_PUBLIC_B24_FIELD_CLIENT_NAME=
NUXT_PUBLIC_B24_FIELD_CLIENT_UNP=
NUXT_PUBLIC_B24_FIELD_DESCRIPTION=
NUXT_PUBLIC_B24_FIELD_HASH_ID=
NUXT_PUBLIC_B24_FIELD_CATEGORY=
NUXT_PUBLIC_B24_FIELD_METHOD=
NUXT_PUBLIC_B24_FIELD_DOC_DATE_TIME=

# Enum IDs (list item IDs) for the category / type / method fields.
NUXT_PUBLIC_B24_PAYMENT_CATEGORY_IN=
NUXT_PUBLIC_B24_PAYMENT_CATEGORY_OUT=
NUXT_PUBLIC_B24_PAYMENT_TYPE_FULL=
NUXT_PUBLIC_B24_PAYMENT_METHOD_NON_CASH=
